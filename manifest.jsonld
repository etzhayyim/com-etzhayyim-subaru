{
  "@context": {
    "@vocab": "https://etzhayyim.com/ns/actor#",
    "id": "@id",
    "type": "@type"
  },
  "id": "actor:subaru",
  "type": "Actor",
  "name": "subaru",
  "glyph": "昴",
  "purpose": "Transparent connectivity-commons satellite constellation — the charter-clean inversion of Starlink/OneWeb. Connectivity delivered as §1.16 Social Security in-kind (covenantal-universal, to the unconnected + disaster zones); cash≡0, no ads, no subscription, no surveillance. Operates spacecraft (unlike hoshimori which only observes), but ONLY Transparently. The payload torifune launches; observed by hoshimori for stewardship.",
  "status": "R0+R1-design-and-sim",
  "tier": "B",
  "adr": "2606162355",
  "dependsOnAdr": ["2605192100", "2605302357", "2606073600", "2606162355", "2605181100", "2606051600", "2605312345", "2605215000"],
  "schema": ["00-contracts/schemas/constellation-ontology.kotoba.edn"],
  "substrate": {
    "state": "kotoba Datom log (ADR-2605312345) — methods/datom_emit.py emits canonical EAVT (R1)",
    "largeAssets": "DataLad → IPFS (80-data/constellation) — NO git-lfs",
    "inference": "Murakumo-only (ADR-2605215000)",
    "confidentiality": "com.etzhayyim.encrypted.* (XChaCha20-Poly1305 + Signal per-recipient keys, DID-bound) — ADR-2605181100; subaru routes ciphertext it cannot read",
    "links": "noroshi (光電融合 photonics) inter-satellite + ground links — ADR-2606051600",
    "runtime": "kotoba pywasm actor (componentize-py) — pure-stdlib methods, no numpy (R1)"
  },
  "integrates": ["actor:torifune", "actor:hoshimori", "actor:watatsuna", "actor:tsutae", "actor:noroshi", "actor:watari"],
  "lineage": "orbital member of the connectivity family (watatsuna submarine cable / tsutae handheld terminal / noroshi photonics links); the payload torifune builds + launches; observed by hoshimori; named 昴 (Pleiades; verb すばる = to unite/gather — a constellation that connects)",
  "cells": [
    {
      "id": "cell:subaru.link-budget",
      "method": "methods/link_budget.py",
      "input": "data/seed-constellation.kotoba.edn",
      "output": ["out/link-budget-report.md"],
      "pipeline": "per-link EIRP / path-loss / G/T / margin (ground↔sat, inter-sat optical via noroshi); coverage % per :service-area (aggregate region, never a person)",
      "doc": "connectivity engineering; service keyed to service-area, no user-location attribute exists (G1/G2)"
    },
    {
      "id": "cell:subaru.coverage",
      "method": "methods/coverage.py",
      "input": "data/seed-constellation.kotoba.edn",
      "output": ["out/coverage-report.md"],
      "pipeline": "shell occupancy → ground coverage per service-area → §1.16 entitlement reach (unconnected / disaster-zone prioritization)",
      "doc": "coverage as social-security reach (§1.16 in-kind), not a market map"
    },
    {
      "id": "cell:subaru.stewardship",
      "method": "methods/stewardship.py",
      "input": "data/seed-constellation.kotoba.edn",
      "output": ["out/stewardship-report.md"],
      "pipeline": "deorbit-debt + disposal plan + night-sky brightness (darksat) → hoshimori-consumable stewardship input; refuses a shell design with no disposal plan",
      "doc": "orbital stewardship (G5) — couples hoshimori + torifune G5; reduce congestion, never add"
    },
    {
      "id": "cell:subaru.datom-emit",
      "method": "methods/datom_emit.py",
      "input": "data/seed-constellation.kotoba.edn",
      "output": ["out/constellation-datoms.kotoba.edn"],
      "pipeline": "ground EAVT datoms [e a v tx :add] (durable) + derived readouts (coverage %, link margin, deorbit-debt) flagged :bond/is-transient (computed on read)",
      "doc": "kotoba Datom-log projection — first-class canonical state (ADR-2605312345)"
    }
  ],
  "gates": {
    "G1": "connectivity COMMONS, NEVER a surveillance / targeting / military-C2 platform — NO deep-packet inspection, NO traffic-content inspection, NO user-geolocation-as-product, NO ISR/targeting relay; military-exclusive C2 + jamming-as-weapon UNREPRESENTABLE (§1.12 + Rider §2(a),(c)); test asserts no DPI/user-location-product/targeting-relay attribute",
    "G2": "no person-tracking; reciprocal-symmetric only (Rider §2(c) v3.1) — subscriber content E2E encrypted (com.etzhayyim.encrypted.*, ADR-2605181100); subaru routes ciphertext it cannot read; no traffic-metadata retention-as-product; privacy by encryption not by metadata graph",
    "G3": "non-profit / no-ads / cash≡0 — connectivity is §1.16 in-kind social security (covenantal-universal, conversion-gated Level-0); external = donation/in-kind only; SBT↔SBT internal carve-out (ADR-2605192115); NO subscription, NO advertising, NO data-as-payment",
    "G4": "Transparent constellation — open-source bus + protocol + on-chain ops log + 1 SBT = 1 vote (§1.12); never covert/proprietary",
    "G5": "orbital stewardship (couples hoshimori + torifune G5) — low-deorbit-debt orbit + mandatory disposal plan + night-sky brightness mitigation (darksat, Wellbecoming §1.13); no new debris; footprint feeds hoshimori congestion integral",
    "G6": "spectrum/coordination honesty — ITU + national coordination DISCLOSED + respected (non-adjudicating N3); no harmful interference; no unlicensed/covert band use",
    "G7": "Murakumo-only narration (ADR-2605215000)",
    "G8": "no-server-key; live constellation operation Council + operator-DID gated (R0 = link-budget + coverage + design sim + ontology only)"
  }
}
